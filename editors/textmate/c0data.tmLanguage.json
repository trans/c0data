{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "C0DATA",
  "scopeName": "source.c0data",
  "fileTypes": ["c0", "c0data"],
  "patterns": [
    { "include": "#file-separator" },
    { "include": "#group-separator" },
    { "include": "#header" },
    { "include": "#record" },
    { "include": "#eot" },
    { "include": "#quoted" },
    { "include": "#escape" },
    { "include": "#reference" },
    { "include": "#substitution" },
    { "include": "#unit-separator" }
  ],
  "repository": {
    "file-separator": {
      "match": "(␜)(.*$)",
      "captures": {
        "1": { "name": "keyword.control.file-separator.c0data" },
        "2": { "name": "entity.name.section.file.c0data" }
      }
    },
    "group-separator": {
      "match": "(␝+)(␁)?([^␞␟␁␂␃␄␅␐␚␜␝]*)",
      "captures": {
        "1": { "name": "keyword.control.group-separator.c0data" },
        "2": { "name": "storage.type.schema-marker.c0data" },
        "3": { "name": "entity.name.section.group.c0data" }
      }
    },
    "header": {
      "begin": "(␁)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "keyword.control.header.c0data" }
      },
      "patterns": [
        { "include": "#unit-separator" },
        {
          "match": "[^␟]+",
          "name": "variable.other.header-field.c0data"
        }
      ]
    },
    "record": {
      "begin": "(␞)",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "keyword.control.record-separator.c0data" }
      },
      "patterns": [
        { "include": "#quoted" },
        { "include": "#escape" },
        { "include": "#reference" },
        { "include": "#substitution" },
        { "include": "#unit-separator" },
        {
          "match": "[^␟␂␃␅␐␚]+",
          "name": "string.unquoted.field.c0data"
        }
      ]
    },
    "eot": {
      "match": "␄",
      "name": "keyword.control.eot.c0data"
    },
    "quoted": {
      "begin": "␂",
      "end": "␃",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.c0data" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.c0data" }
      },
      "name": "string.quoted.other.c0data",
      "patterns": [
        { "include": "#escape" },
        { "include": "#unit-separator" }
      ]
    },
    "escape": {
      "match": "(␐)(.)",
      "captures": {
        "1": { "name": "constant.character.escape.marker.c0data" },
        "2": { "name": "constant.character.escape.value.c0data" }
      }
    },
    "reference": {
      "match": "(␅)([^␟␞␝␜␁␂␃␄␐␚\\s]+)",
      "captures": {
        "1": { "name": "keyword.control.reference.c0data" },
        "2": { "name": "variable.other.reference.c0data" }
      }
    },
    "substitution": {
      "match": "␚",
      "name": "keyword.operator.substitution.c0data"
    },
    "unit-separator": {
      "match": "␟",
      "name": "punctuation.separator.field.c0data"
    }
  }
}
